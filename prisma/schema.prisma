generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Quality {
  FIRST
  END
}

enum Surface {
  MAT
  SLP
  FLP
  SGR
  GLS
  SOFT_ANTISLIP
  ANTISLIP
  R10
  R11
}

enum OrderStatus {
  NEW
  CORRECTION_REQUESTED
  REVIEWED
  APPROVED
  REJECTED
}

enum AdminRole {
  SUPER
  BRAND_MANAGER
}

enum AccessRequestType {
  SALESPERSON
  DEALER
}

enum AccessRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model Brand {
  id        String          @id @default(cuid())
  name      String
  slug      String          @unique
  logoText  String?
  sortOrder Int             @default(0)
  /** false ise marka katalogda hiç görünmez (her izleyici için gizli). */
  isVisible Boolean         @default(true)
  /** false ise marka yalnızca plasiyerlere görünür, bayilere kapalıdır. */
  visibleToDealers Boolean  @default(true)
  families  ProductFamily[]
  admins    AdminUser[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model ProductFamily {
  id             String           @id @default(cuid())
  brandId        String
  brand          Brand            @relation(fields: [brandId], references: [id], onDelete: Cascade)
  name           String
  slug           String
  imageUrl       String?
  imagePublicId  String?
  imageUpdatedAt DateTime?
  sortOrder      Int              @default(0)
  isActive       Boolean          @default(true)
  /** Önceden tanımlı renk kimliği (product-attributes.ts). */
  color          String?
  /** Önceden tanımlı görünüm/tip kimliği: mermer, ahsap, beton... */
  materialType   String?
  variants       ProductVariant[]
  clickStat      FamilyClickStat?
  clickEvents    FamilyClickEvent[]
  similarOf      SimilarFamily[]  @relation("FamilyToSimilar")
  similarTo      SimilarFamily[]  @relation("SimilarToFamily")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([brandId, slug])
  @@index([brandId])
}

/**
 * Benzer ürün ilişkisi (aile↔aile). Simetrik tutulur: her çift iki yönlü
 * (A→B ve B→A) satır olarak yazılır, böylece okuma tek kolondan yapılır.
 */
model SimilarFamily {
  id              String        @id @default(cuid())
  familyId        String
  family          ProductFamily @relation("FamilyToSimilar", fields: [familyId], references: [id], onDelete: Cascade)
  similarFamilyId String
  similarFamily   ProductFamily @relation("SimilarToFamily", fields: [similarFamilyId], references: [id], onDelete: Cascade)
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())

  @@unique([familyId, similarFamilyId])
  @@index([familyId])
  @@index([similarFamilyId])
}

model FamilyClickStat {
  familyId  String        @id
  family    ProductFamily @relation(fields: [familyId], references: [id], onDelete: Cascade)
  count     Int           @default(0)
  updatedAt DateTime      @updatedAt

  @@index([count])
}

/**
 * Olay düzeyinde tıklama kaydı: hangi aileye, kim (bayi/plasiyer), ne zaman,
 * kaç kez. Toplu gönderimde her aile için bir satır (sayı ile). Bayi/plasiyer
 * ve tarih bazlı raporlar bundan üretilir.
 */
model FamilyClickEvent {
  id            String        @id @default(cuid())
  familyId      String
  family        ProductFamily @relation(fields: [familyId], references: [id], onDelete: Cascade)
  deviceId      String?
  salespersonId String?
  salesperson   Salesperson?  @relation(fields: [salespersonId], references: [id], onDelete: SetNull)
  /** "dealer" | "salesperson" | "unknown" */
  actorType     String        @default("unknown")
  /** Bayi adı veya plasiyer adı (o anki anlık kopya). */
  actorName     String?
  count         Int           @default(1)
  createdAt     DateTime      @default(now())

  @@index([familyId, createdAt])
  @@index([salespersonId, createdAt])
  @@index([createdAt])
}

model ProductVariant {
  id            String        @id @default(cuid())
  familyId      String
  family        ProductFamily @relation(fields: [familyId], references: [id], onDelete: Cascade)
  size          String
  surface       Surface
  quality       Quality
  feature3D     Boolean       @default(false)
  featureRec    Boolean       @default(false)
  code          String?
  /** Netsis stok kodları — bir varyantın birden çok kodu olabilir. */
  netsisCodes   VariantNetsisCode[]
  price          Int?
  palletM2      Float?
  boxM2         Float?
  truckM2       Float?
  imageUrl       String?
  imagePublicId  String?
  imageUpdatedAt DateTime?
  isActive       Boolean       @default(true)
  stockLines StockLine[]
  orderLines OrderLine[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([familyId, size, surface, quality, feature3D, featureRec])
  @@index([familyId, size])
}

model VariantNetsisCode {
  id        String         @id @default(cuid())
  /** Netsis stok kodu — global benzersiz; tek bir varyanta işaret eder. */
  code      String         @unique
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@index([variantId])
}

model StockLine {
  id          String         @id @default(cuid())
  variantId   String
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  label       String
  quantityM2  Float
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([variantId])
}

model Salesperson {
  id             String      @id @default(cuid())
  name           String
  isActive       Boolean     @default(true)
  showStock      Boolean     @default(true)
  lockedDeviceId String?     @unique
  lockedDevice   Device?     @relation("SalespersonDeviceLock", fields: [lockedDeviceId], references: [id], onDelete: SetNull)
  devices        Device[]
  accessRequests AccessRequest[]
  orders         Order[]
  visits         SiteVisit[]
  clickEvents    FamilyClickEvent[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Device {
  id                 String       @id @default(cuid())
  token              String       @unique @default(cuid())
  salespersonId      String?
  salesperson        Salesperson? @relation(fields: [salespersonId], references: [id])
  lockForSalesperson Salesperson? @relation("SalespersonDeviceLock")
  /** Bayi cihazları için stok görünürlüğü. Varsayılan kapalı; admin açar. */
  showStock          Boolean      @default(false)
  label              String?
  registeredAt       DateTime     @default(now())
  lastSeenAt         DateTime     @default(now())
  visits             SiteVisit[]
  accessRequests     AccessRequest[]
}

model SiteVisit {
  id            String       @id @default(cuid())
  deviceId      String?
  device        Device?      @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  salespersonId String?
  salesperson   Salesperson? @relation(fields: [salespersonId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())

  @@index([createdAt])
  @@index([salespersonId, createdAt])
}

model Order {
  id                String         @id @default(cuid())
  orderNumber       String         @unique
  salespersonId     String?
  salesperson       Salesperson?   @relation(fields: [salespersonId], references: [id])
  dealerName        String
  notes             String?
  correctionNote    String?
  status            OrderStatus    @default(NEW)
  approvedByAdminId String?
  approvedByAdmin   AdminUser?     @relation("OrderApprovedBy", fields: [approvedByAdminId], references: [id])
  approvedAt        DateTime?
  lines             OrderLine[]
  adminLogs         OrderAdminLog[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([status])
}

model OrderAdminLog {
  id          String    @id @default(cuid())
  orderId     String
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  adminUserId String
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id])
  adminName   String
  action      String
  message     String?
  createdAt   DateTime  @default(now())

  @@index([orderId])
}

model OrderLine {
  id               String         @id @default(cuid())
  orderId          String
  order            Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId        String
  variant          ProductVariant @relation(fields: [variantId], references: [id])
  quantityM2       Float
  unitPriceSnapshot Int
  productLabel     String

  @@index([orderId])
}

model AdminUser {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String
  password  String
  /** Şifre her değiştiğinde güncellenir; eski oturum cookie'lerini geçersizler. */
  passwordChangedAt DateTime @default(now())
  role      AdminRole @default(BRAND_MANAGER)
  brandId   String?
  brand     Brand?    @relation(fields: [brandId], references: [id])
  /** JSON dizi: families, images, prices, ... — null ise role varsayılanı */
  permissions String?
  approvedOrders Order[]         @relation("OrderApprovedBy")
  orderLogs      OrderAdminLog[]
  accessRequests AccessRequest[] @relation("AccessRequestApprovedBy")
  auditLogs      AdminAuditLog[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  body      String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/**
 * Admin denetim izi: kritik yönetim işlemlerinin (fiyat/stok/ürün/renk-tip/
 * marka/netsis/satış vb.) kim tarafından ne zaman yapıldığını tutar.
 */
model AdminAuditLog {
  id          String    @id @default(cuid())
  adminUserId String?
  adminUser   AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)
  adminName   String
  /** Kısa işlem kodu: "price.update", "stock.import", "family.attributes" ... */
  action      String
  /** İlgili varlık tipi: "family" | "variant" | "brand" | "settings" ... */
  entityType  String?
  entityId    String?
  /** İnsan-okur özet ("12 ürünün stoğu güncellendi" gibi). */
  summary     String?
  /** Ek ayrıntılar JSON (opsiyonel). */
  meta        String?
  createdAt   DateTime  @default(now())

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([adminUserId, createdAt])
}

model AppSettings {
  id                   String   @id @default("default")
  lastPriceListUpdate  DateTime @default(now())
  /** Katalogdan satış (sepet/sipariş) açık mı? Kapalıyken sepet gizlenir. */
  salesEnabled         Boolean  @default(true)
  updatedAt            DateTime @updatedAt
}

model AccessRequest {
  id                  String              @id @default(cuid())
  type                AccessRequestType
  status              AccessRequestStatus @default(PENDING)
  salespersonId       String?
  salesperson         Salesperson?        @relation(fields: [salespersonId], references: [id], onDelete: SetNull)
  dealerName          String?
  requestToken        String              @unique
  requestLabel        String
  deviceId            String?
  device              Device?             @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  approvedByAdminId   String?
  approvedByAdmin     AdminUser?          @relation("AccessRequestApprovedBy", fields: [approvedByAdminId], references: [id], onDelete: SetNull)
  rejectionReason     String?
  notifiedAt          DateTime?
  approvedAt          DateTime?
  completedAt         DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([status, createdAt])
  @@index([type, createdAt])
  @@index([salespersonId, status])
}
